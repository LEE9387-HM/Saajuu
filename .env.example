# Browser-safe Supabase config for the Vite client.
# Paste only the publishable/anon key here. Never use the service_role key in Vite.
VITE_SUPABASE_URL=
# Preferred browser-safe key for Supabase Auth / Data API access from the Vite client.
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias. Use only one browser-safe key value.
VITE_SUPABASE_ANON_KEY=
VITE_PORTONE_STORE_ID=
VITE_PORTONE_CHANNEL_KEY=

# Server-only secrets for Supabase Edge Functions or another backend runtime.
# Do not prefix these with VITE_ and do not commit real values.
SUPABASE_SERVICE_ROLE_KEY=
LLM_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
OPENAI_API_KEY=
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=

# Optional bootstrap allowlist for the admin Edge Function.
# Set this only in Supabase Edge Function secrets, not in Vite env files.
# Example: ADMIN_EMAILS=owner@example.com,ops@example.com
ADMIN_EMAILS=
